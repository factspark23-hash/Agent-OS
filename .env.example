# Agent-OS Production Environment Variables
# Copy to .env and fill in your values
#
# IMPORTANT: Agent-OS runs 100% self-contained without ANY of these keys.
# All keys below are OPTIONAL — add them only if you want enhanced features.
# Run `python main.py --setup` for an interactive setup wizard.

# ─── Authentication ─────────────────────────────────────
# JWT secret key (min 32 chars). Generate with: openssl rand -hex 32
# If not set, auto-generated on startup (won't survive restarts)
JWT_SECRET_KEY=

# Legacy agent token (optional, for backward compat)
AGENT_TOKEN=

# ─── Database (Optional) ────────────────────────────────
POSTGRES_PASSWORD=change-me-to-a-strong-password

# ─── Browser Engine ─────────────────────────────────────
# Firefox fallback (auto-switches when Chromium is detected)
# BROWSER_FIREFOX_FALLBACK=true

# ─── Cloudflare Bypass ──────────────────────────────────
# Enable enhanced CF bypass engine (v1/v2/v3 + Turnstile)
# CF_BYPASS_ENABLED=true

# ─── Optional: CAPTCHA Solving ──────────────────────────
# Agent-OS has built-in CAPTCHA prevention (blocking scripts).
# Add a key here for auto-solving CAPTCHAs on protected sites.
# CAPTCHA_API_KEY=your-2captcha-or-anticaptcha-key

# ─── Optional: Proxy Rotation ──────────────────────────
# Agent-OS has built-in TLS fingerprint spoofing + smart retries.
# Add proxy provider for large-scale residential rotation.
# PROXY_PROVIDER=brightdata
# PROXY_PROVIDER_CUSTOMER_ID=
# PROXY_PROVIDER_ZONE=residential
# PROXY_PROVIDER_PASSWORD=
# PROXY_PROVIDER_COUNTRIES=US,GB,DE,FR

# Proxy file (alternative to provider)
# PROXY_FILE=/path/to/proxies.txt

# Auto-proxy settings
# AUTO_PROXY_BASE_DELAY=2.0
# AUTO_PROXY_MAX_DELAY=120.0
# AUTO_PROXY_BURN_COOLDOWN=300

# ─── Optional: Whisper Transcription (Local) ────────────
# Uses local Whisper model — FREE, but needs: pip install openai-whisper
# WHISPER_MODEL=tiny

# ─── Optional: LLM Enhancement ─────────────────────────
# Agent-OS has rule-based page analysis (works without any LLM).
# Add your key for smarter summarization & content analysis.
# LLM_API_KEY=your-openai-anthropic-or-groq-key
# LLM_API_BASE=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# ─── Optional ───────────────────────────────────────────
# Custom config file path
# CONFIG_PATH=/path/to/config.yaml

# Log level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO
