# Agent-OS Production Environment Variables
# Copy to .env and fill in your values

# ─── Database ────────────────────────────────────────────
POSTGRES_PASSWORD=change-me-to-a-strong-password

# ─── Authentication ─────────────────────────────────────
# JWT secret key (min 32 chars). Generate with: openssl rand -hex 32
# If not set, auto-generated on startup (won't survive restarts)
JWT_SECRET_KEY=

# Legacy agent token (optional, for backward compat)
AGENT_TOKEN=

# ─── Browser Engine ─────────────────────────────────────
# Firefox fallback (auto-switches when Chromium is detected)
# BROWSER_FIREFOX_FALLBACK=true

# ─── Cloudflare Bypass ──────────────────────────────────
# Enable enhanced CF bypass engine (v1/v2/v3 + Turnstile)
# CF_BYPASS_ENABLED=true

# ─── Auto-Proxy Rotation ───────────────────────────────
# Proxy provider (brightdata, oxylabs, smartproxy, iproyal)
# PROXY_PROVIDER=brightdata
# PROXY_PROVIDER_CUSTOMER_ID=
# PROXY_PROVIDER_ZONE=residential
# PROXY_PROVIDER_PASSWORD=
# PROXY_PROVIDER_COUNTRIES=US,GB,DE,FR

# Proxy file (alternative to provider)
# PROXY_FILE=/path/to/proxies.txt

# Auto-proxy settings
# AUTO_PROXY_BASE_DELAY=2.0
# AUTO_PROXY_MAX_DELAY=120.0
# AUTO_PROXY_BURN_COOLDOWN=300

# ─── Optional ───────────────────────────────────────────
# Custom config file path
# CONFIG_PATH=/path/to/config.yaml

# Log level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO
