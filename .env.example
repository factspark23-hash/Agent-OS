# Agent-OS Environment Variables
# Copy this file to .env and customize

# Agent authentication token
# If not set, Agent-OS auto-generates one on startup
AGENT_TOKEN=my-agent-token-123

# Proxy (optional)
# Supports: http://user:pass@host:port, https://..., socks5://host:port
#AGENT_PROXY=http://user:pass@proxy.example.com:8080

# Device emulation (optional)
# Options: iphone_se, iphone_14, iphone_14_pro_max, ipad, ipad_pro,
#          galaxy_s23, galaxy_tab_s9, pixel_8, desktop_1080, desktop_1440, desktop_4k
#AGENT_DEVICE=desktop_1080

# Server ports
#AGENT_WS_PORT=8000
#AGENT_HTTP_PORT=8001
#AGENT_DEBUG_PORT=8002

# Browser settings
#AGENT_HEADLESS=true
#AGENT_MAX_RAM_MB=500

# Rate limiting (requests per minute per token/IP)
#AGENT_RATE_LIMIT=60

# Disable debug UI (reduces attack surface in production)
# Recommended: set to true in production
#AGENT_NO_DEBUG=true

# Config file path (optional)
#AGENT_CONFIG=~/.agent-os/config.yaml
